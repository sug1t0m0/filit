{
  "name": "filit",
  "version": "0.0.0",
  "description": "CLI that bundles selected files into a single browser page so tab-aware LLMs (Gemini in Chrome, etc.) can ingest them at once",
  "keywords": [
    "browser",
    "cli",
    "context",
    "llm",
    "prompt",
    "react"
  ],
  "homepage": "https://github.com/sug1t0m0/filit",
  "bugs": {
    "url": "https://github.com/sug1t0m0/filit/issues"
  },
  "license": "MIT",
  "author": "sug1t0m0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sug1t0m0/filit.git"
  },
  "bin": {
    "filit": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/cli/index.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "pnpm run build:cli && vite build",
    "build:cli": "tsc --project tsconfig.cli.json",
    "start": "pnpm run build && node dist/cli/index.js",
    "typecheck": "tsc --noEmit",
    "check": "oxlint . --deny-warnings --report-unused-disable-directives",
    "check:fix": "oxlint . --deny-warnings --report-unused-disable-directives --fix",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "lefthook install",
    "prepublishOnly": "NODE_ENV=production pnpm run build"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "express": "^5.1.0",
    "fast-glob": "^3.3.3",
    "fflate": "^0.8.3",
    "ignore": "^7.0.5",
    "open": "^11.0.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.11",
    "@tsconfig/strictest": "^2.0.5",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.8",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.4.21",
    "happy-dom": "^20.0.0",
    "lefthook": "^2.0.0",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.49.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "vite": "^8.0.0",
    "vitest": "^4.0.6"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.0.6"
}
